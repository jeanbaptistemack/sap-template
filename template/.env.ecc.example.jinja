# =============================================================================
# {{ project_name }} — Credentials SAP ECC EHP8 (second sap-adt-mcp instance)
# Copier vers .env.ecc et remplir les valeurs. Ne jamais committer .env.ecc.
#
# Ce fichier est sourcé par /opt/sap-adt-mcp/scripts/mcp-server-ecc.sh, qui
# force ensuite MCP_PORT=8001, MCP_HOST=127.0.0.1, log → logs/server-ecc.log
# et PID → .mcp-server-ecc.pid. Les vars SAP_* ci-dessous écrasent celles de
# .env (qui cible le S/4HANA sur 8000).
# =============================================================================

# --- SAP ECC EHP8 (NetWeaver 7.50) ---
SAP_URL=https://<ecc-host>:44300
SAP_USER=DEVELOPER
SAP_PASSWORD=
SAP_CLIENT=100
SAP_LANGUAGE=EN
SAP_VERIFY_SSL=false

# --- RFC ECC (optionnel) ---
# SAP_ASHOST=<ecc-host>
# SAP_SYSNR=00
# SAP_RFC_ALLOWLIST=

# --- Stack hint (optionnel) ---
# Le serveur auto-détecte le stack via system_info, mais on peut forcer :
# SAP_STACK=ecc_ehp8
