# =============================================================================
# {{ project_name }} — Variables d'environnement
# Copier vers .env et remplir les valeurs. Ne jamais committer .env.
# Gestion des secrets : op inject -i .env.example -o .env  (1Password CLI)
# =============================================================================

# --- SAP Connexion (HTTP/ADT) ---
SAP_URL=https://s4hdev.duckdns.org:44300
SAP_HOSTNAME=s4hdev.duckdns.org
SAP_USER=DEVELOPER
SAP_PASSWORD=
SAP_CLIENT=100
SAP_LANGUAGE=EN
SAP_VERIFY_SSL=false

# Mode de déploiement des MCP servers (local, ssh, docker)
DEPLOYMENT_MODE=local

# Désactiver la vérification TLS (certificat auto-signé SAP dev)
NODE_TLS_REJECT_UNAUTHORIZED=0
{%- if project_type == "mcp-server" or project_type == "abap-project" %}

# --- SAP RFC (pyrfc / node-rfc) ---
SAP_ASHOST=s4hdev.duckdns.org
SAP_SYSNR=00
# Liste blanche des fonctions RFC autorisées (séparées par virgules, vide = toutes)
SAP_RFC_ALLOWLIST=
{%- endif %}
{%- if project_type == "mcp-server" %}

# --- SAP GUI Bridge (COM automation Windows) ---
SAP_BRIDGE_URL=http://sap-bridge:8001
SAP_BRIDGE_HOST=0.0.0.0
SAP_BRIDGE_PORT=8001

# SAP WebGUI (transaction browser)
SAP_WEBGUI_URL=https://s4hdev.duckdns.org:44300/sap/bc/gui/sap/its/webgui?sap-client=100&sap-language=EN

# Connexion SAP GUI (format: "nom_connexion" dans saplogon.ini)
SAP_CONNECTION=

# --- Serveur MCP ---
MCP_HOST=0.0.0.0
MCP_PORT=8000
{%- endif %}
{%- if project_type == "abap-project" or project_type == "fabric-pipeline" %}

# --- HANA Database (accès direct) ---
HANA_HOST=s4hdev.duckdns.org
HANA_PORT=30213
HANA_USER=HANA_DEV
HANA_PASSWORD=
HANA_DB=HDB
{%- endif %}
{%- if project_type == "fabric-pipeline" %}

# --- Azure / Microsoft Fabric ---
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=

# OneLake / Fabric
ONELAKE_WORKSPACE_ID=
ONELAKE_LAKEHOUSE_ID=
FABRIC_CAPACITY_ID=

# ADLS Gen2 (accès direct)
AZURE_STORAGE_ACCOUNT=
AZURE_ADLS_ENDPOINT=
AZURE_SAS_TOKEN=
{%- endif %}

# --- GitHub ---
# PAT nécessaire pour les scripts abapGit (deploy/pull)
GITHUB_PERSONAL_ACCESS_TOKEN=

# --- DNS dynamique (infrastructure SAP dev) ---
DUCKDNS_TOKEN=
DUCKDNS_DOMAIN=s4hdev

# --- SSH appliance SAP ---
# Chemin vers la clé privée SSH de l'appliance (ne pas committer)
SAP_PEM_PATH=./ssh_appliance.pem
