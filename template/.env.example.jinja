# =============================================================================
# {{ project_name }} — Variables d'environnement
# Copier vers .env et remplir les valeurs. Ne jamais committer .env.
# =============================================================================

# --- GitHub ---
GITHUB_PERSONAL_ACCESS_TOKEN=

# --- SAP Connexion (HTTP/ADT) ---
SAP_URL=https://192.168.50.112:44300
SAP_USER=DEVELOPER
SAP_PASSWORD=
SAP_CLIENT=100
SAP_LANGUAGE=FR
SAP_VERIFY_SSL=false

# Mode de déploiement (adt, rfc, local)
DEPLOYMENT_MODE=adt

# Désactiver la vérification TLS (certificat auto-signé SAP dev)
NODE_TLS_REJECT_UNAUTHORIZED=0
{%- if project_type == "mcp-server" or project_type == "abap-project" %}

# --- SAP RFC (pyrfc / node-rfc) ---
SAP_ASHOST=192.168.50.112
SAP_SYSNR=00
# Liste blanche des fonctions RFC autorisées (séparées par virgules, vide = toutes)
SAP_RFC_ALLOWLIST=
{%- endif %}
{%- if project_type == "mcp-server" %}

# --- SAP GUI VM (Windows) ---
MCP_VM_USER=
MCP_VM_PORT=8001

# SAP WebGUI (transaction browser)
SAP_WEBGUI_URL=https://192.168.50.112:44300/sap/bc/gui/sap/its/webgui?sap-client=100&sap-language=FR

# Connexion SAP GUI (format: "nom_connexion" dans saplogon.ini)
SAP_CONNECTION=

# --- Serveur MCP ---
MCP_HOST=0.0.0.0
MCP_PORT=8000
{%- endif %}
{%- if project_type == "abap-project" or project_type == "fabric-pipeline" %}

# --- HANA Direct ---
SAP_HANA_HOST=192.168.50.111
SAP_HANA_PORT=30041
SAP_HANA_USER=SAPHANADB
SAP_HANA_PASSWORD=
SAP_HANA_SCHEMA=SAPHANADB
{%- endif %}
{%- if project_type == "fabric-pipeline" %}

# --- Azure / Microsoft Fabric ---
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=

# OneLake / Fabric
ONELAKE_WORKSPACE_ID=
ONELAKE_LAKEHOUSE_ID=
FABRIC_CAPACITY_ID=

# ADLS Gen2 (accès direct)
AZURE_STORAGE_ACCOUNT=
AZURE_ADLS_ENDPOINT=
AZURE_SAS_TOKEN=
{%- endif %}
