{
  "name": "{{ project_name }}-devcontainer",
  "image": "mcr.microsoft.com/devcontainers/python:{{ python_version }}",

  "mounts": [
    "source=${localEnv:HOME}/.claude,target=/home/vscode/.claude,type=bind",
    "source=${localEnv:HOME}/.ssh,target=/home/vscode/.ssh,type=bind,readonly"
  ],

  "features": {
    "ghcr.io/devcontainers/features/node:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/git-lfs:1": {}{% if enable_iac %},
    "ghcr.io/devcontainers/features/azure-cli:1": {},
    "ghcr.io/devcontainers-extra/features/opentofu:1": {}{% endif %}
  },

  "initializeCommand": "mkdir -p ${HOME}/.claude",

  "customizations": {
    "vscode": {
      "extensions": [
        "Anthropic.claude-code",
        "humao.rest-client",
        "redhat.vscode-yaml",
        "ms-azuretools.vscode-azureresourcegroups",
        "bierner.markdown-mermaid"{% if enable_iac %},
        "ms-azuretools.vscode-bicep"{% endif %}
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },

  "onCreateCommand": {
    "git-config": "git config --global --add safe.directory ${containerWorkspaceFolder} && git config --global user.email '{{ author_email }}' && git config --global user.name '{{ author_name }}'",
    "claude-dirs": "mkdir -p /home/vscode/.claude/tmp /home/vscode/.claude/logs /tmp/claude-code"
  },

  "postCreateCommand": "bash ${containerWorkspaceFolder}/.devcontainer/post-create.sh",

  "postStartCommand": "bash ${containerWorkspaceFolder}/.devcontainer/post-start.sh",

  "remoteUser": "vscode",
  "userEnvProbe": "loginShell",

  "remoteEnv": {
    "PATH": "${containerEnv:HOME}/.local/bin:${containerEnv:HOME}/.claude/bin:${containerEnv:PATH}",
    "TMPDIR": "/tmp/claude-code",

    "CLAUDE_CODE_EFFORT_LEVEL": "max",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "128000",
    "CLAUDE_CODE_MAX_TOOL_USE_CONCURRENCY": "20"
  },

  "containerEnv": {
    "HOME": "/home/vscode",
    "HISTFILE": "${containerWorkspaceFolder}/.bash_history"
  }
}
