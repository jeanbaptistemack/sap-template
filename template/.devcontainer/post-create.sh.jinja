#!/bin/bash
# =============================================================================
# {{ project_name }} — Post-create script
# Runs once after container build (postCreateCommand)
# =============================================================================

WORKSPACE_DIR="${containerWorkspaceFolder:-$(pwd)}"
cd "$WORKSPACE_DIR"

echo "============================================"
echo "  {{ project_name }} — post-create setup..."
echo "============================================"

# =============================================================================
# 1. uv + copier
# =============================================================================
echo "[1/4] Claude auth restore..."
if [ ! -f "$HOME/.claude.json" ]; then
  BACKUP=$(ls "$HOME/.claude/backups/.claude.json.backup."* 2>/dev/null | sort | tail -1)
  if [ -n "$BACKUP" ]; then
    cp "$BACKUP" "$HOME/.claude.json"
    echo "  ~/.claude.json restored from backup"
  else
    echo "  no backup found — first run, auth required"
  fi
else
  echo "  ~/.claude.json already present"
fi

echo "[3/4] uv + copier..."
if command -v uv &>/dev/null; then
  echo "  uv $(uv --version)"
else
  curl -LsSf https://astral.sh/uv/install.sh | sh 2>/dev/null && echo "  uv installed" || echo "  WARNING: uv install failed"
fi
export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$PATH"
echo 'export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$PATH"' >> ~/.bashrc

if command -v copier &>/dev/null; then
  echo "  copier $(copier --version)"
else
  pip install copier --quiet 2>/dev/null && echo "  copier installed" || echo "  WARNING: copier install failed"
fi

# =============================================================================
# 2. Claude Code CLI
# =============================================================================
echo "[4/4] Claude Code CLI..."
if command -v claude &>/dev/null; then
  echo "  claude $(claude --version)"
else
  curl -fsSL https://claude.ai/install.sh | bash 2>/dev/null || \
    npm install -g @anthropic-ai/claude-code 2>/dev/null || \
    echo "  WARNING: install failed — run manually"
fi
export PATH="$HOME/.local/bin:$HOME/.claude/bin:$PATH"
echo 'export PATH="$HOME/.local/bin:$HOME/.claude/bin:$PATH"' >> ~/.bashrc

# =============================================================================
# 3. Dépendances Python du projet
# =============================================================================
echo "[5/5] Python dependencies..."
if [ -f "$WORKSPACE_DIR/pyproject.toml" ]; then
  uv sync --all-extras 2>/dev/null && echo "  uv sync done" || echo "  WARNING: uv sync failed"
  # Committer uv.lock s'il vient d'être généré
  if git -C "$WORKSPACE_DIR" status --short 2>/dev/null | grep -q "uv.lock"; then
    git -C "$WORKSPACE_DIR" add uv.lock && \
    git -C "$WORKSPACE_DIR" commit -m "chore: add uv.lock" --quiet && \
    git -C "$WORKSPACE_DIR" push --quiet 2>/dev/null && \
    echo "  uv.lock committed and pushed" || echo "  WARNING: uv.lock commit failed"
  fi
else
  echo "  no pyproject.toml — skipping"
fi

# =============================================================================
# 4. Git submodules
# =============================================================================
echo "[5/5] Git submodules..."
if [ -f "$WORKSPACE_DIR/.gitmodules" ]; then
  git submodule update --init --recursive 2>/dev/null && echo "  submodules initialized" || echo "  WARNING: failed"
else
  echo "  no submodules — skipping"
fi

echo ""
echo "============================================"
echo "  Post-create complete!"
echo "============================================"
